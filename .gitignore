logs/
*.log
npm-debug.log*
yarn-debug.log*

# ─── OS generated ────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Test coverage output ────────────────────────────────────────────────────
coverage/

