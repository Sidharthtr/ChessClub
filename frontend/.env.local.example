# Local development env vars for the Vite dev server (no Docker).
# Copy to frontend/.env.local — Vite loads it automatically and gitignore keeps it local.
#
#   cp frontend/.env.local.example frontend/.env.local

# Point to the backend running directly on your machine
VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws
